{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["vitest/globals", "node"],
    "lib": ["ES2022"]
  },
  "include": [
    "tests/**/*.ts",
    "vitest.config.ts",
    "vitest.e2e.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
