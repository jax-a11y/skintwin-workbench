{
  "name": "skintwin-workbench",
  "version": "1.0.0",
  "description": "SkinTwin Cognitive Alchemist Workbench - AI-driven beauty-tech ecosystem integration platform",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "lint:openapi": "npm run lint:openapi:youcam && npm run lint:openapi:shopify",
    "lint:openapi:youcam": "spectral lint docs/api/openapi.json --ruleset .spectral.json",
    "lint:openapi:shopify": "spectral lint docs/api/shopify-app-openapi.json --ruleset .spectral.json",
    "lint:docs": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:smoke": "vitest run --config vitest.e2e.config.ts --grep 'smoke|critical'",
    "test:e2e:exhaustive": "vitest run --config vitest.e2e.config.ts --grep 'exhaustive|negative|edge'",
    "test:coverage": "vitest run --coverage",
    "validate": "npm run lint:openapi && npm run lint:docs",
    "diff:openapi": "oasdiff breaking docs/api/shopify-app-openapi.json",
    "ci:pr": "npm run validate && npm run test:e2e:smoke",
    "ci:full": "npm run validate && npm run test:e2e",
    "ci:nightly": "npm run validate && npm run test:e2e:exhaustive"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.11.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "markdownlint-cli2": "^0.13.0",
    "msw": "^2.3.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "skincare",
    "ai",
    "shopify",
    "mrp",
    "scm",
    "beauty-tech"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/jax-a11y/skintwin-workbench.git"
  }
}
